<mxfile host="app.diagrams.net" type="device">
  <diagram id="bot-arch" name="Bot architecture">
    <mxGraphModel dx="1400" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1960" pageHeight="1226" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="CoronaPoker — Bot subsystem architecture" style="text;html=1;fontSize=24;fontStyle=1;fontColor=#1a1a2e;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="6" width="1300" height="30" as="geometry"/></mxCell>
        <mxCell id="subtitle" value="Top → bottom: the live game drives the decision engine, which leans on opponent modelling and a swappable hand-evaluation stack down to the Alberta combinatorial core. The «interface» seams (DealerView / BotPlayerView / BotEvaluator) let the offline QA harness fake the whole table without Swing." style="text;html=1;fontSize=13;fontStyle=2;fontColor=#5a5a6a;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="40" width="1760" height="20" as="geometry"/></mxCell>
        <mxCell id="c2" value="GAME INTEGRATION  —  live table (Spanish domain)" style="swimlane;rounded=1;arcSize=4;startSize=30;html=1;fillColor=#5B82BE;swimlaneFillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#ffffff;fontStyle=1;fontSize=14;align=left;verticalAlign=middle;spacingLeft=18;" vertex="1" parent="1"><mxGeometry x="40" y="100" width="1840" height="128" as="geometry"/></mxCell>
        <mxCell id="c3" value="&lt;b&gt;Crupier&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Dealer · drives each bot turn · implements DealerView&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F0F5FD;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c2"><mxGeometry x="215" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c4" value="&lt;b&gt;GameFrame&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Global DIFFICULTY · BOT_THINK_TIME (1500 ms)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F0F5FD;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c2"><mxGeometry x="575" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c5" value="&lt;b&gt;DealerView  «interface»&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Read-only table slice (street, pot, bets, blinds, positions)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F0F5FD;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c2"><mxGeometry x="935" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c6" value="&lt;b&gt;BotPlayerView  «interface»&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Read-only player slice (stack, bet, hole cards, active)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F0F5FD;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c2"><mxGeometry x="1295" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c7" value="DECISION ENGINE  —  Bot.java  (one instance per CPU seat)" style="swimlane;rounded=1;arcSize=4;startSize=30;html=1;fillColor=#7E57A6;swimlaneFillColor=#EDE3FA;strokeColor=#7E57A6;strokeWidth=1.5;fontColor=#ffffff;fontStyle=1;fontSize=14;align=left;verticalAlign=middle;spacingLeft=18;" vertex="1" parent="1"><mxGeometry x="40" y="288" width="1840" height="128" as="geometry"/></mxCell>
        <mxCell id="c8" value="&lt;b&gt;Bot&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;calculateBotDecision(opponents) → BET / CHECK-CALL / FOLD&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F4ECFC;strokeColor=#7E57A6;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c7"><mxGeometry x="215" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c9" value="&lt;b&gt;Personality&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Difficulty {EASY,MEDIUM,HARD} · Skill {REC,REG,SHARK} · Profile {NIT,STATION,TAG,LAG}&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F4ECFC;strokeColor=#7E57A6;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c7"><mxGeometry x="575" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c10" value="&lt;b&gt;Per-hand state&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;streetPlan · scareCard · tilt · slowPlay · float · cBetInitiative&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F4ECFC;strokeColor=#7E57A6;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c7"><mxGeometry x="935" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c11" value="&lt;b&gt;Bet sizing&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;getBetSize() · board-texture fractions · RNG jitter&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F4ECFC;strokeColor=#7E57A6;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c7"><mxGeometry x="1295" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c12" value="OPPONENT MODELLING  —  populated by the dealer every action" style="swimlane;rounded=1;arcSize=4;startSize=30;html=1;fillColor=#D79B00;swimlaneFillColor=#FFEFD6;strokeColor=#D79B00;strokeWidth=1.5;fontColor=#ffffff;fontStyle=1;fontSize=14;align=left;verticalAlign=middle;spacingLeft=18;" vertex="1" parent="1"><mxGeometry x="40" y="476" width="1840" height="128" as="geometry"/></mxCell>
        <mxCell id="c13" value="&lt;b&gt;OpponentTracker&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;VPIP · PFR · AF (aggression factor)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#FFF6E8;strokeColor=#D79B00;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c12"><mxGeometry x="395" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c14" value="&lt;b&gt;Reads&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;isStation / isNit / isManiac / looksPassiveStation&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#FFF6E8;strokeColor=#D79B00;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c12"><mxGeometry x="755" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c15" value="&lt;b&gt;TRACKER_MEMORY&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Per-nick stats · persists across hands of the session&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#FFF6E8;strokeColor=#D79B00;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c12"><mxGeometry x="1115" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c16" value="HAND EVALUATION  —  BotEvaluator abstraction (Card-encoding 0..51)" style="swimlane;rounded=1;arcSize=4;startSize=30;html=1;fillColor=#0E9C9C;swimlaneFillColor=#DAF2F3;strokeColor=#0E9C9C;strokeWidth=1.5;fontColor=#ffffff;fontStyle=1;fontSize=14;align=left;verticalAlign=middle;spacingLeft=18;" vertex="1" parent="1"><mxGeometry x="40" y="664" width="1840" height="128" as="geometry"/></mxCell>
        <mxCell id="c17" value="&lt;b&gt;BotEvaluator  «interface»&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;HandStrength + DrawPotential + HandRank (umbrella)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#E9F8F8;strokeColor=#0E9C9C;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c16"><mxGeometry x="215" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c18" value="&lt;b&gt;MemoizedAlbertaEvaluator&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Production · memoized PPot/NPot (~8× on the flop)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#E9F8F8;strokeColor=#0E9C9C;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c16"><mxGeometry x="575" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c19" value="&lt;b&gt;AlbertaEvaluatorAdapter&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Reference oracle (uncached) · the equivalence baseline&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#E9F8F8;strokeColor=#0E9C9C;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c16"><mxGeometry x="935" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c20" value="&lt;b&gt;Potential&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;PPot / NPot pair (positive / negative potential)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#E9F8F8;strokeColor=#0E9C9C;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c16"><mxGeometry x="1295" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c21" value="ALBERTA ENGINE  —  U. Alberta Poker Research Group (org.alberta.poker)" style="swimlane;rounded=1;arcSize=4;startSize=30;html=1;fillColor=#5E9E5E;swimlaneFillColor=#E5F3E3;strokeColor=#5E9E5E;strokeWidth=1.5;fontColor=#ffffff;fontStyle=1;fontSize=14;align=left;verticalAlign=middle;spacingLeft=18;" vertex="1" parent="1"><mxGeometry x="40" y="852" width="1840" height="128" as="geometry"/></mxCell>
        <mxCell id="c22" value="&lt;b&gt;HandPotential&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;ppot_raw / ppot · Papp 1998 §5.3 roll-out&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#EFF8EE;strokeColor=#5E9E5E;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c21"><mxGeometry x="215" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c23" value="&lt;b&gt;MemoizedHandPotential&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Cached 7-card ranks (own + opponent table)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#EFF8EE;strokeColor=#5E9E5E;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c21"><mxGeometry x="575" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c24" value="&lt;b&gt;HandEvaluator&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;rankHand() · native libeval | Java fallback&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#EFF8EE;strokeColor=#5E9E5E;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c21"><mxGeometry x="935" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c25" value="&lt;b&gt;Deck · Hand · Card&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Deterministic combinatorial primitives&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#EFF8EE;strokeColor=#5E9E5E;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c21"><mxGeometry x="1295" y="42" width="330" height="74" as="geometry"/></mxCell>
        <mxCell id="c26" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2.5;endArrow=block;endFill=1;" edge="1" parent="1" source="c2" target="c7"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c27" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2.5;endArrow=block;endFill=1;" edge="1" parent="1" source="c7" target="c12"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c28" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2.5;endArrow=block;endFill=1;" edge="1" parent="1" source="c12" target="c16"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c29" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2.5;endArrow=block;endFill=1;" edge="1" parent="1" source="c16" target="c21"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c30" value="reads villain reads" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=1;html=1;dashed=1;dashPattern=10 6;exitX=1;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#D79B00;strokeWidth=2;endArrow=block;endFill=1;fontColor=#9c7200;fontStyle=2;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="c7" target="c12"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1912" y="352"/><mxPoint x="1912" y="540"/></Array></mxGeometry></mxCell>
        <mxCell id="legend" value="&lt;b&gt;How a turn flows&lt;/b&gt;  (▼ solid = depends on / built upon · ┄ dashed = consults)&lt;br&gt;&lt;b&gt;Crupier&lt;/b&gt; reaches a CPU seat → calls &lt;b&gt;Bot.calculateBotDecision(opponents)&lt;/b&gt; → the engine queries the &lt;b&gt;BotEvaluator&lt;/b&gt; for hand strength and PPot/NPot, blends them into an &lt;i&gt;effective strength&lt;/i&gt;, adjusts by &lt;b&gt;OpponentTracker&lt;/b&gt; reads, profile and board texture, and returns BET / CHECK-CALL / FOLD plus a cached bet size.&lt;br&gt;&lt;b&gt;Effective strength&lt;/b&gt; = strength + (1 − strength)·PPot − strength·NPot   (Papp 1998).&lt;br&gt;&lt;b&gt;Swappable evaluation:&lt;/b&gt; production wires &lt;b&gt;MemoizedAlbertaEvaluator&lt;/b&gt;; &lt;b&gt;AlbertaEvaluatorAdapter&lt;/b&gt; stays untouched as the numeric reference the equivalence test compares against (identical PPot/NPot, ~8× faster on the flop two-card look-ahead).&lt;br&gt;&lt;b&gt;The «interface» seams&lt;/b&gt; (DealerView · BotPlayerView · BotEvaluator) are the testability boundary: the offline QA harness (tools/qa) injects fake dealers, players and a deterministic RNG so thousands of hands run head-less, without Swing or sockets." style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#FBFBFD;strokeColor=#9aa0b0;strokeWidth=1.5;fontColor=#2a2a35;fontSize=11.5;align=left;verticalAlign=top;spacingLeft=16;spacingTop=12;spacingRight=12;" vertex="1" parent="1"><mxGeometry x="40" y="1006" width="1840" height="190" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>