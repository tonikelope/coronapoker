<mxfile host="app.diagrams.net" type="device">
  <diagram id="bot-flow" name="Bot decision flow">
    <mxGraphModel dx="1400" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1540" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="CoronaPoker — Bot per-turn decision flow" style="text;html=1;fontSize=24;fontStyle=1;fontColor=#1a1a2e;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="-30" width="1200" height="30" as="geometry"/></mxCell>
        <mxCell id="start" value="&lt;b&gt;Crupier reaches a CPU seat&lt;/b&gt;&lt;br&gt;Bot.calculateBotDecision(opponents)" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#E5F3E3;strokeColor=#5E9E5E;strokeWidth=2;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="500" y="30" width="500" height="54" as="geometry"/></mxCell>
        <mxCell id="decPre" value="&lt;b&gt;street ==&lt;br&gt;PREFLOP ?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFEFD6;strokeColor=#D79B00;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="615" y="120" width="270" height="96" as="geometry"/></mxCell>
        <mxCell id="preEval" value="&lt;b&gt;determinePosition()  ·  evaluateHandTier()&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;tier 1 premium … 5 trash · position EARLY/MIDDLE/LATE/BLINDS&lt;/span&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EDE3FA;strokeColor=#7E57A6;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="40" y="132" width="430" height="72" as="geometry"/></mxCell>
        <mxCell id="preAct" value="&lt;b&gt;calculatePreflopAction&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;position × profile × bet level →&lt;br&gt;open · 3-bet/4-bet/5-bet value · call · fold&lt;br&gt;squeeze · 3-bet bluff (blockers)&lt;br&gt;HU button steal &amp;amp; BB defend (difficulty looseness offset)&lt;/span&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EDE3FA;strokeColor=#7E57A6;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="40" y="250" width="430" height="132" as="geometry"/></mxCell>
        <mxCell id="pf1" value="&lt;b&gt;handStrengthVsN → strength&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;equity vs N random hands · cached per street&lt;/span&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="510" y="270" width="480" height="52" as="geometry"/></mxCell>
        <mxCell id="pf2" value="&lt;b&gt;potential() → PPot / NPot&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;2-card look-ahead on the flop · river = 0&lt;/span&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="510" y="352" width="480" height="52" as="geometry"/></mxCell>
        <mxCell id="pf3" value="&lt;b&gt;effective strength = strength + (1−s)·PPot − s·NPot&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;− overcard / weak-kicker penalties · floor 0.10&lt;/span&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="490" y="434" width="520" height="64" as="geometry"/></mxCell>
        <mxCell id="pf4" value="&lt;b&gt;scare-card detection&lt;/b&gt; (Δ &amp;lt; −0.15 on a new street)&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;on the FLOP: generateStreetPlan → { BET·BET·BET | BET·CHK·BET | CHK·CALL | none }&lt;/span&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="490" y="528" width="520" height="64" as="geometry"/></mxCell>
        <mxCell id="pf5" value="&lt;b&gt;winProb adjustments&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;multiway · 3-bet+ pots · scare card · out of position · villain read (nit / maniac / station) · shark edge · EASY noise&lt;/span&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="490" y="622" width="520" height="70" as="geometry"/></mxCell>
        <mxCell id="pf6" value="&lt;b&gt;EV(call) · EV(raise) · fold equity&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;implied odds for safe draws · fold equity = 0 vs a station&lt;/span&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="540" y="722" width="420" height="52" as="geometry"/></mxCell>
        <mxCell id="decFace" value="&lt;b&gt;facing a bet ?&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;betCount &amp;gt; 0&lt;/span&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFEFD6;strokeColor=#D79B00;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="605" y="812" width="290" height="104" as="geometry"/></mxCell>
        <mxCell id="chkBox" value="&lt;b&gt;decisionWhenCheckedTo&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;slow-play trap · flop C-bet (range advantage)&lt;br&gt;semi-bluff (street-aware PPot threshold)&lt;br&gt;river: value · thin value · polarized bluff (fold-equity gated)&lt;br&gt;street-plan barrels · EV value bet&lt;br&gt;→ &lt;b&gt;BET&lt;/b&gt; or &lt;b&gt;CHECK&lt;/b&gt;&lt;/span&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E9F8F8;strokeColor=#0E9C9C;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="70" y="962" width="540" height="150" as="geometry"/></mxCell>
        <mxCell id="facBox" value="&lt;b&gt;decisionWhenFacingBet&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;dynamic check-raise · float · pot-committed shove/call&lt;br&gt;value raise · medium raise (heads-up only) · squeeze&lt;br&gt;implied-odds draw call · MDF bluff-catch (HARD)&lt;br&gt;→ &lt;b&gt;BET&lt;/b&gt; · &lt;b&gt;CHECK/CALL&lt;/b&gt; · &lt;b&gt;FOLD&lt;/b&gt;&lt;/span&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F4ECFC;strokeColor=#7E57A6;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="870" y="962" width="560" height="150" as="geometry"/></mxCell>
        <mxCell id="raw" value="&lt;b&gt;raw decision&lt;/b&gt;: BET / CHECK-CALL / FOLD" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="500" y="1160" width="500" height="56" as="geometry"/></mxCell>
        <mxCell id="decMis" value="&lt;b&gt;recreational mistake ?&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;roll &amp;lt; rate · EASY 45% · MEDIUM 22% · HARD 0%&lt;/span&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFEFD6;strokeColor=#D79B00;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="585" y="1256" width="330" height="110" as="geometry"/></mxCell>
        <mxCell id="misBox" value="&lt;b&gt;injectRecreationalMistake&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;sticky calldown · hero fold · missed value bet · spewy preflop call&lt;/span&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FBE2E1;strokeColor=#C0504D;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="70" y="1270" width="430" height="82" as="geometry"/></mxCell>
        <mxCell id="end" value="&lt;b&gt;final ACTION → dealer&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;executes the cached getBetSize() after BOT_THINK_TIME (1500 ms)&lt;/span&gt;" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#E5F3E3;strokeColor=#5E9E5E;strokeWidth=2;fontColor=#1f1f1f;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="490" y="1420" width="520" height="64" as="geometry"/></mxCell>
        <mxCell id="e0" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2;endArrow=block;endFill=1;fontColor=#333333;fontSize=10;fontStyle=2;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="start" target="decPre"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1" value="preflop" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2;endArrow=block;endFill=1;fontColor=#333333;fontSize=10;fontStyle=2;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="decPre" target="preEval"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="postflop" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2;endArrow=block;endFill=1;fontColor=#333333;fontSize=10;fontStyle=2;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="decPre" target="pf1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2;endArrow=block;endFill=1;fontColor=#333333;fontSize=10;fontStyle=2;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="preEval" target="preAct"><mxGeometry relative="1" as="geometry"/></mxCell>
