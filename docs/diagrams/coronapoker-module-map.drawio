        <mxCell id="e3" value="wire commands" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=1;html=1;dashed=1;dashPattern=8 6;endArrow=block;endFill=1;strokeColor=#5B82BE;strokeWidth=2;fontColor=#3f5e94;fontStyle=2;fontSize=10;labelBackgroundColor=#ffffff;exitX=0.6;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="lobby" target="crupier"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="creates / runs  ·  shared state" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=1;html=1;startArrow=block;startFill=1;endArrow=block;endFill=1;strokeColor=#C0504D;strokeWidth=2.5;fontColor=#9c403d;fontStyle=2;fontSize=10;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="gameframe" target="crupier"><mxGeometry relative="1" as="geometry"/></mxCell>
