        <mxCell id="band3" value="SUPPORT SERVICES" style="swimlane;rounded=1;arcSize=3;startSize=30;html=1;fillColor=#5B82BE;swimlaneFillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#ffffff;fontStyle=1;fontSize=14;align=left;verticalAlign=middle;spacingLeft=18;" vertex="1" parent="1"><mxGeometry x="40" y="640" width="1720" height="140" as="geometry"/></mxCell>
