        <mxCell id="helpers" value="&lt;b&gt;Helpers  —  shared utilities &amp;amp; persistence&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;SQLite · secure channel (AES-CBC + HMAC) · threading/EDT · imaging/fonts · money formatting · OS abstraction  ·  used by EVERY module&lt;/span&gt;" style="rounded=1;arcSize=14;whiteSpace=wrap;html=1;fillColor=#F7F7F7;strokeColor=#5C5C5C;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="300" y="872" width="1200" height="70" as="geometry"/></mxCell>
