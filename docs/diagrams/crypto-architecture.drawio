        <mxCell id="c15" value="&lt;b&gt;RistrettoSRA&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Commutative SRA over Ristretto255 (lock=·k, unlock=k⁻¹)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#EFF8EE;strokeColor=#5E9E5E;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c14"><mxGeometry x="46" y="46" width="180" height="66" as="geometry"/></mxCell>
