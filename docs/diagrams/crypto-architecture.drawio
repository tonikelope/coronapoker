        <mxCell id="c47" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2.5;endArrow=block;endFill=1;" edge="1" parent="1" source="c5" target="c10"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c48" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2.5;endArrow=block;endFill=1;" edge="1" parent="1" source="c10" target="c14"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c49" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2.5;endArrow=block;endFill=1;" edge="1" parent="1" source="c14" target="c24"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c50" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2.5;endArrow=block;endFill=1;" edge="1" parent="1" source="c24" target="c32"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="divider" value="╌╌╌   CROSS-CUTTING INFRASTRUCTURE — consumed by every layer, independent of the verifiable-deal dependency chain   ╌╌╌" style="text;html=1;fontSize=12;fontStyle=2;fontColor=#666666;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="1104" width="1840" height="34" as="geometry"/></mxCell>
        <mxCell id="c51" value="Crupier / WaitingRoomFrame
use Ed25519 identity" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=1;html=1;dashed=1;dashPattern=10 6;exitX=1;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#C0504D;strokeWidth=2;endArrow=block;endFill=1;fontColor=#9c403d;fontStyle=2;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="c2" target="c36"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1912" y="136"/><mxPoint x="1912" y="1276"/></Array></mxGeometry></mxCell>
        <mxCell id="c52" value="… and the secure channel
for every wire payload" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=1;html=1;dashed=1;dashPattern=10 6;exitX=1;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#5B82BE;strokeWidth=2;endArrow=block;endFill=1;fontColor=#3f5e94;fontStyle=2;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="c2" target="c40"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1948" y="136"/><mxPoint x="1948" y="1456"/></Array></mxGeometry></mxCell>
        <mxCell id="legend" value="&lt;b&gt;Dependency map&lt;/b&gt;  (▼ solid = uses / built upon · ┄ dashed = cross-cutting infrastructure)&lt;br&gt;&lt;b&gt;Verifiable-deal stack:&lt;/b&gt;  Orchestration → Consensus → Wire Codecs → Shuffle &amp;amp; Dealing → Proof blocks → Group/Field primitives.&lt;br&gt;&amp;nbsp;&amp;nbsp;• ShuffleCascade → ShuffleArgument → { PermutationArgument → ProductArgument → MultiplicationProof , WeightedSumArgument } → PedersenVectorCommit → Ristretto255&lt;br&gt;&amp;nbsp;&amp;nbsp;• DualLockCascade → { ShuffleCascade , RotationProof }   ·   DealChain → VerifiableUnlock → Dleq → Transcript   ·   ShuffleVerificationQueue → DualLockWire → DualLockCascade&lt;br&gt;&amp;nbsp;&amp;nbsp;• HandStateChain → { CanonicalActionRecord , SettlementRecord , IdentityManager }   ·   ProofCodec → ShuffleArgument   ·   UnlockChainWire → DealChain&lt;br&gt;&amp;nbsp;&amp;nbsp;• All arithmetic descends to:  Ristretto255 → EdwardsPoint → Fe25519&lt;br&gt;&lt;b&gt;Cross-cutting infrastructure:&lt;/b&gt;  the secure channel (AES-CBC + HMAC-SHA256) carries EVERY wire payload; Ed25519 Identity signs actions/JOIN/receipts/showdown. Both are consumed by Orchestration &amp;amp; Consensus but are independent of the math stack.&lt;br&gt;&lt;b&gt;Notes:&lt;/b&gt;  the &lt;i&gt;genesis&lt;/i&gt; (52 Ristretto255 points) never travels — each peer recomputes it as the trust anchor.  The legacy &lt;i&gt;CryptoSRA&lt;/i&gt; engine (Montgomery x-only) was retired → today &lt;b&gt;RistrettoSRA&lt;/b&gt; + &lt;b&gt;DeterministicShuffle&lt;/b&gt;." style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#FBFBFD;strokeColor=#9aa0b0;strokeWidth=1.5;fontColor=#2a2a35;fontSize=11.5;align=left;verticalAlign=top;spacingLeft=16;spacingTop=12;spacingRight=12;" vertex="1" parent="1"><mxGeometry x="40" y="1538" width="1840" height="200" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
