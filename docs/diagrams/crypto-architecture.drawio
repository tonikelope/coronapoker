        <mxCell id="c21" value="&lt;b&gt;VerifiableUnlock&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Unlock + DLEQ proof of the committed key&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#EFF8EE;strokeColor=#5E9E5E;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c14"><mxGeometry x="1222" y="46" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="c22" value="&lt;b&gt;DealChain&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Per-card DLEQ chain (anchor = commitment)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#EFF8EE;strokeColor=#5E9E5E;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c14"><mxGeometry x="1418" y="46" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="c23" value="&lt;b&gt;DeckTransform&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;out[i] = k·deck[perm[i]] + helpers&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#EFF8EE;strokeColor=#5E9E5E;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c14"><mxGeometry x="1614" y="46" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="c24" value="PROOF BUILDING BLOCKS  (ZK)" style="swimlane;rounded=1;arcSize=4;startSize=30;html=1;fillColor=#C9A23A;swimlaneFillColor=#FFF6D9;strokeColor=#C9A23A;strokeWidth=1.5;fontColor=#ffffff;fontStyle=1;fontSize=14;align=left;verticalAlign=middle;spacingLeft=18;" vertex="1" parent="1"><mxGeometry x="40" y="796" width="1840" height="120" as="geometry"/></mxCell>
        <mxCell id="c25" value="&lt;b&gt;Transcript&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Fiat-Shamir SHA-512 (absorbs public values)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#FFFAE8;strokeColor=#C9A23A;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c24"><mxGeometry x="242" y="46" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="c26" value="&lt;b&gt;Dleq&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Chaum-Pedersen: equality of dlogs (c‖s, 64 B)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#FFFAE8;strokeColor=#C9A23A;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c24"><mxGeometry x="438" y="46" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="c27" value="&lt;b&gt;PedersenVectorCommit&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;C = r·H + Σ aᵢ·Gᵢ (perfectly hiding)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#FFFAE8;strokeColor=#C9A23A;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c24"><mxGeometry x="634" y="46" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="c28" value="&lt;b&gt;MultiplicationProof&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Σ-protocol: c = a·b mod L&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#FFFAE8;strokeColor=#C9A23A;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c24"><mxGeometry x="830" y="46" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="c29" value="&lt;b&gt;ProductArgument&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Grand product: Π aᵢ = b&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#FFFAE8;strokeColor=#C9A23A;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c24"><mxGeometry x="1026" y="46" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="c30" value="&lt;b&gt;PermutationArgument&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;d′ is a permutation of d (Neff)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#FFFAE8;strokeColor=#C9A23A;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c24"><mxGeometry x="1222" y="46" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="c31" value="&lt;b&gt;WeightedSumArgument&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Q = Σ fᵢ·Bᵢ (multi-exp)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#FFFAE8;strokeColor=#C9A23A;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c24"><mxGeometry x="1418" y="46" width="180" height="66" as="geometry"/></mxCell>
