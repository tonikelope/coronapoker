        <mxCell id="c41" value="&lt;b&gt;NetServer&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Host socket · carries the encrypted wire&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F0F5FD;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c40"><mxGeometry x="438" y="46" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="c42" value="&lt;b&gt;NetClient&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Client socket · carries the encrypted wire&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F0F5FD;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c40"><mxGeometry x="634" y="46" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="c43" value="&lt;b&gt;WireFrame&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Frame codec · text «*» / binary 0x00 (DoS-bounded)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F0F5FD;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c40"><mxGeometry x="830" y="46" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="c44" value="&lt;b&gt;BinaryWire&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;Binary layout (only after HMAC is verified)&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F0F5FD;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c40"><mxGeometry x="1026" y="46" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="c45" value="&lt;b&gt;Helpers · Channel&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#3a3a3a&quot;&gt;AES/CBC + HMAC-SHA256 (encrypt-then-MAC); key ⟵ ECDH+SHA-512&lt;/span&gt;" style="rounded=1;arcSize=16;whiteSpace=wrap;html=1;fillColor=#F0F5FD;strokeColor=#5B82BE;strokeWidth=1.5;fontColor=#1f1f1f;fontSize=11;verticalAlign=middle;align=center;spacingLeft=4;spacingRight=4;" vertex="1" parent="c40"><mxGeometry x="1222" y="46" width="180" height="66" as="geometry"/></mxCell>
