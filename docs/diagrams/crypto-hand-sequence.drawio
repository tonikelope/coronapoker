        <mxCell id="s15" value="&lt;b&gt;START_SRA_CASCADE&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;releases the cascade · HOST mints HAND_ID (random 16 B)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="916" as="sourcePoint"/><mxPoint x="780" y="916" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s16" value="&lt;b&gt;START_SRA_CASCADE&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;releases the cascade · HOST mints HAND_ID (random 16 B)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="970" as="sourcePoint"/><mxPoint x="1260" y="970" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s17" value="HOST applies its own k_pocket over the genesis + Fisher-Yates AES-256-CTR shuffle.
Every member holds two ephemeral scalars: k_pocket and k_community." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="1060" width="380" height="52" as="geometry"/></mxCell>
        <mxCell id="s18" value="&lt;b&gt;DECK_CASCADE_REQ&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;deck after HOST&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="1152" as="sourcePoint"/><mxPoint x="780" y="1152" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s19" value="validates 52 points · generates k_pocket / k_community · lock + shuffle
