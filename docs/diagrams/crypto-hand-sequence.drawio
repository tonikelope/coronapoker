        <mxCell id="s131" value="PHASE 1 · Shuffle — commutative SRA lock cascade  (ring order HOST → C1 → C2)" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#E5F3E3;strokeColor=#5E9E5E;strokeWidth=1.5;opacity=55;fontColor=#222222;fontStyle=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="20" y="1011" width="1660" height="1178" as="geometry"/></mxCell>
