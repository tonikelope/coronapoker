        <mxCell id="s136" value="PHASE 4b · Turn — community reveal" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=1.5;opacity=55;fontColor=#222222;fontStyle=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="20" y="5042" width="1660" height="591" as="geometry"/></mxCell>
        <mxCell id="s137" value="PHASE 3c · Turn betting" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#FFEFD6;strokeColor=#D79B00;strokeWidth=1.5;opacity=55;fontColor=#222222;fontStyle=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="20" y="5651" width="1660" height="374" as="geometry"/></mxCell>
        <mxCell id="s138" value="PHASE 4c · River — community reveal" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=1.5;opacity=55;fontColor=#222222;fontStyle=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="20" y="6043" width="1660" height="591" as="geometry"/></mxCell>
        <mxCell id="s139" value="PHASE 3d · River betting" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#FFEFD6;strokeColor=#D79B00;strokeWidth=1.5;opacity=55;fontColor=#222222;fontStyle=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="20" y="6652" width="1660" height="374" as="geometry"/></mxCell>
        <mxCell id="s140" value="PHASE 5 · Showdown  (k_pocket reveal, signed)" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#FBE2E1;strokeColor=#C0504D;strokeWidth=1.5;opacity=55;fontColor=#222222;fontStyle=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="20" y="7044" width="1660" height="674" as="geometry"/></mxCell>
        <mxCell id="s141" value="PHASE 6 · Settlement + receipt consensus  (certifies the hand)" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#EDE3FA;strokeColor=#7E57A6;strokeWidth=1.5;opacity=55;fontColor=#222222;fontStyle=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="20" y="7736" width="1660" height="696" as="geometry"/></mxCell>
        <mxCell id="s142" value="CROSS-CUTTING · Anti-replay / lockdown / misdeal" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#F0F0F0;strokeColor=#777777;strokeWidth=1.5;opacity=55;fontColor=#222222;fontStyle=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="20" y="8450" width="1660" height="192" as="geometry"/></mxCell>
