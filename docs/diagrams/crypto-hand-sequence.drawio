        <mxCell id="t1" value="CoronaPoker — Per-hand cryptographic protocol (verifiable SRA)" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#1a1a2e;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="20" y="6" width="1400" height="28" as="geometry"/></mxCell>
        <mxCell id="t2" value="One COMPLETE hand — all four streets (preflop · flop · turn · river) through to showdown — with every step shown explicitly. 3-player game: HOST (dealer + player, server) + 2 human clients. Time flows downward. ── solid = send · ┄ dashed = response · purple = host push (one explicit arrow per client)." style="text;html=1;fontSize=12;fontStyle=2;fontColor=#5a5a6a;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="20" y="32" width="1640" height="20" as="geometry"/></mxCell>
        <mxCell id="s2" value="&lt;b&gt;TCP CONNECT + ECDH&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C1 sends its ephemeral Curve25519 pubkey&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="200" as="sourcePoint"/><mxPoint x="300" y="200" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s3" value="&lt;b&gt;ECDH + HOST IDENTITY&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;host ephemeral pubkey + host Ed25519 identity&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="256" as="sourcePoint"/><mxPoint x="780" y="256" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s4" value="Both sides run ECDH → deriveChannelSecret: HMAC-SHA512(shared ‖ password)
→ AES-256 channel key + HMAC-256 key. C1 pins the host identity (TOFU)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="286" width="380" height="52" as="geometry"/></mxCell>
        <mxCell id="s5" value="&lt;b&gt;JOIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C1 pubkey + Ed25519 self-sig «JOIN\0» ‖ session_id ‖ nick ‖ pubkey&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="378" as="sourcePoint"/><mxPoint x="300" y="378" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s6" value="verifyJoin(C1) + TOFU pin (NEW / MATCH / CHANGED)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="408" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s7" value="&lt;b&gt;TCP CONNECT + ECDH&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C2 sends its ephemeral Curve25519 pubkey&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="485" as="sourcePoint"/><mxPoint x="300" y="485" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s8" value="&lt;b&gt;ECDH + HOST IDENTITY&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;host ephemeral pubkey + host Ed25519 identity&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="541" as="sourcePoint"/><mxPoint x="1260" y="541" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s9" value="deriveChannelSecret(C2) → C2 AES-256 + HMAC-256 keys. C2 pins the host identity (TOFU)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="571" width="380" height="37" as="geometry"/></mxCell>
