        <mxCell id="s102" value="&lt;b&gt;ACTION (relay)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;host forwards C1 signed action to C2&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="6270" as="sourcePoint"/><mxPoint x="1260" y="6270" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s103" value="&lt;b&gt;ACTION&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;( FOLD · CHECK · CALL · BET · RAISE · ALL-IN ) · C2 acts, signs «ACTION\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="6326" as="sourcePoint"/><mxPoint x="300" y="6326" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s104" value="&lt;b&gt;ACTION (relay)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;host forwards C2 signed action to C1&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="6382" as="sourcePoint"/><mxPoint x="780" y="6382" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s105" value="&lt;b&gt;ACTION&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;( FOLD · CHECK · CALL · BET · RAISE · ALL-IN ) · HOST acts, signs «ACTION\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="6436" as="sourcePoint"/><mxPoint x="780" y="6436" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s106" value="&lt;b&gt;ACTION&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;( FOLD · CHECK · CALL · BET · RAISE · ALL-IN ) · HOST acts, signs «ACTION\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="6490" as="sourcePoint"/><mxPoint x="1260" y="6490" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s107" value="HOST contributes its own k_pocket directly (it is a player — no request to itself)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="6580" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s108" value="&lt;b&gt;REQ_SHOWDOWN_KEY&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;to surviving human C1&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="6657" as="sourcePoint"/><mxPoint x="780" y="6657" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s109" value="&lt;b&gt;RESP_SHOWDOWN_KEY&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;k_pocket(C1) + Ed25519 sig «SHOWDOWN\0» ‖ HAND_ID ‖ nick ‖ k_pocket&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="6713" as="sourcePoint"/><mxPoint x="300" y="6713" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s110" value="&lt;b&gt;REQ_SHOWDOWN_KEY&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;to surviving human C2&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="6769" as="sourcePoint"/><mxPoint x="1260" y="6769" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s111" value="&lt;b&gt;RESP_SHOWDOWN_KEY&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;k_pocket(C2) + Ed25519 sig «SHOWDOWN\0» ‖ HAND_ID ‖ nick ‖ k_pocket&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="6825" as="sourcePoint"/><mxPoint x="300" y="6825" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s112" value="verifies each sig + applies the key to the stored single-locked residual + resolves against genesis (forfeit on mismatch). Then it publishes every surviving hand at once." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="6855" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s113" value="&lt;b&gt;POTCARDS&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;ONE atomic message — per surviving player: nick ‖ plaintext cards ‖ sraKey (k_pocket) ‖ Ed25519 sig&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="6930" as="sourcePoint"/><mxPoint x="780" y="6930" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s114" value="&lt;b&gt;POTCARDS&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;ONE atomic message — per surviving player: nick ‖ plaintext cards ‖ sraKey (k_pocket) ‖ Ed25519 sig&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="6984" as="sourcePoint"/><mxPoint x="1260" y="6984" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s115" value="Delivered as ONE atomic POTCARDS message (no early peeking); the single bundle each client gets packs every showing hand (HOST + C1 + C2). To verify, each peer SRA-decrypts the stored single-locked residual of each revealed player with the sraKey that player just published and checks it matches the plaintext (proof nobody cheated)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="7014" width="640" height="37" as="geometry"/></mxCell>
        <mxCell id="s116" value="The hole cards also travel as PLAINTEXT, so SPECTATORS — who hold no SRA keys and cannot decrypt — can still watch the showdown." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="7065" width="640" height="37" as="geometry"/></mxCell>
        <mxCell id="s117" value="&lt;b&gt;HANDVERIFY (trigger)&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;pre-payout barrier · a late MISDEAL here aborts cleanly&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="7200" as="sourcePoint"/><mxPoint x="780" y="7200" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s118" value="&lt;b&gt;HANDVERIFY (trigger)&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;pre-payout barrier · a late MISDEAL here aborts cleanly&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="7254" as="sourcePoint"/><mxPoint x="1260" y="7254" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s119" value="HOST, C1 and C2 each independently compute their SettlementRecord (pot/payout in cents + odd-chip remainder) and absorb it:
H_final = SHA-256( «SETTLE\0» ‖ H_t ‖ settlement table )." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="7284" width="640" height="52" as="geometry"/></mxCell>
        <mxCell id="s120" value="&lt;b&gt;HANDVERIFY # receipt&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C1 receipt 113 B: HAND_ID(16) ‖ H_final(32) ‖ flags(1) ‖ sig(64) Ed25519 «RECEIPT\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="7376" as="sourcePoint"/><mxPoint x="300" y="7376" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s121" value="&lt;b&gt;HANDVERIFY # receipt&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C2 receipt 113 B (same layout)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="7432" as="sourcePoint"/><mxPoint x="300" y="7432" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s122" value="HOST builds and signs its own receipt too, then relays each one so every peer ends up holding all three." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="7462" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s123" value="&lt;b&gt;HANDVERIFY # receipt (relay)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C1 receipt → C2&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="7539" as="sourcePoint"/><mxPoint x="1260" y="7539" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s124" value="&lt;b&gt;HANDVERIFY # receipt (relay)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C2 receipt → C1&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="7595" as="sourcePoint"/><mxPoint x="780" y="7595" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s125" value="&lt;b&gt;HANDVERIFY # receipt&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;HOST receipt → C1&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="7651" as="sourcePoint"/><mxPoint x="780" y="7651" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s126" value="&lt;b&gt;HANDVERIFY # receipt&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;HOST receipt → C2&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="7707" as="sourcePoint"/><mxPoint x="1260" y="7707" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s127" value="Each peer now holds all three receipts and runs the consensus verdict (priority):  DIVERGENT &gt; MISSING &gt; INVALID_SIG_SEEN &gt; DECK_NO_PROOF &gt; DECK_UNVERIFIED &gt; clean." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="7737" width="640" height="37" as="geometry"/></mxCell>
        <mxCell id="s128" value="• Single-use rotation: rotation_served_this_cascade (2nd rotation refused + warn).   • Per-command anti-replay/tamper: encrypt-then-MAC with a per-command IV (bad HMAC ⇒ drop)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="7848" width="640" height="37" as="geometry"/></mxCell>
        <mxCell id="s129" value="• SECURITY_LOCKDOWN (hard): refuses every later crypto request (self-strip / GATE-6 / unanchored chain).   • warnSuspiciousHost (soft): missing/failed proof, replay, out-of-order unlock.   • MISDEAL # reason ⇒ host refunds (cancelarManoYDevolverApuestas)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="7899" width="640" height="37" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>