        <mxCell id="s145" style="endArrow=none;html=1;strokeColor=#5B82BE;strokeWidth=2;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="114" as="sourcePoint"/><mxPoint x="1260" y="8670" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s146" value="&lt;b&gt;HOST&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;Dealer + Player · server&lt;/span&gt;" style="rounded=1;arcSize=20;whiteSpace=wrap;html=1;fillColor=#E8ECF1;strokeColor=#2E3A48;strokeWidth=2;fontColor=#1f1f1f;fontSize=12;" vertex="1" parent="1"><mxGeometry x="205" y="56" width="190" height="58" as="geometry"/></mxCell>
        <mxCell id="s147" value="&lt;b&gt;HOST&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;Dealer + Player · server&lt;/span&gt;" style="rounded=1;arcSize=20;whiteSpace=wrap;html=1;fillColor=#E8ECF1;strokeColor=#2E3A48;strokeWidth=2;fontColor=#1f1f1f;fontSize=12;" vertex="1" parent="1"><mxGeometry x="205" y="8670" width="190" height="58" as="geometry"/></mxCell>
        <mxCell id="s148" value="&lt;b&gt;CLIENT 1&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;human&lt;/span&gt;" style="rounded=1;arcSize=20;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=2;fontColor=#1f1f1f;fontSize=12;" vertex="1" parent="1"><mxGeometry x="685" y="56" width="190" height="58" as="geometry"/></mxCell>
        <mxCell id="s149" value="&lt;b&gt;CLIENT 1&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;human&lt;/span&gt;" style="rounded=1;arcSize=20;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=2;fontColor=#1f1f1f;fontSize=12;" vertex="1" parent="1"><mxGeometry x="685" y="8670" width="190" height="58" as="geometry"/></mxCell>
        <mxCell id="s150" value="&lt;b&gt;CLIENT 2&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;human&lt;/span&gt;" style="rounded=1;arcSize=20;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=2;fontColor=#1f1f1f;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1165" y="56" width="190" height="58" as="geometry"/></mxCell>
        <mxCell id="s151" value="&lt;b&gt;CLIENT 2&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;human&lt;/span&gt;" style="rounded=1;arcSize=20;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=2;fontColor=#1f1f1f;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1165" y="8670" width="190" height="58" as="geometry"/></mxCell>
        <mxCell id="t1" value="CoronaPoker — Per-hand cryptographic protocol (verifiable SRA)" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#1a1a2e;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="20" y="6" width="1400" height="28" as="geometry"/></mxCell>
        <mxCell id="t2" value="One COMPLETE hand — all four streets (preflop · flop · turn · river) through to showdown — with every step shown explicitly. 3-player game: HOST (dealer + player, server) + 2 human clients. Time flows downward. ── solid = send · ┄ dashed = response / async · purple = host push (one explicit arrow per client)." style="text;html=1;fontSize=12;fontStyle=2;fontColor=#5a5a6a;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="20" y="32" width="1640" height="20" as="geometry"/></mxCell>
        <mxCell id="s2" value="&lt;b&gt;TCP CONNECT + ECDH&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C1 sends its ephemeral Curve25519 pubkey&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="200" as="sourcePoint"/><mxPoint x="300" y="200" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s3" value="&lt;b&gt;ECDH pubkey + encrypted INTRO&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;host ephemeral Curve25519 pubkey (raw); then, on the now-encrypted channel, the host INTRO: nick ‖ avatar ‖ session_id ‖ host Ed25519 pubkey ‖ self-sig «JOIN\0»(session_id‖nick‖pubkey)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="256" as="sourcePoint"/><mxPoint x="780" y="256" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s4" value="Both sides run ECDH → deriveChannelSecret: HMAC-SHA512(shared ‖ password) → AES-256 channel key + HMAC-256 key. C1 then captures session_id and pins the host identity FROM THE ENCRYPTED INTRO — verifyJoin(host self-sig) + TOFU (NEW / MATCH / CHANGED). The raw ECDH bytes carry no identity." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="286" width="380" height="106" as="geometry"/></mxCell>
        <mxCell id="s5" value="&lt;b&gt;JOIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C1 pubkey + Ed25519 self-sig «JOIN\0» ‖ session_id ‖ nick ‖ pubkey&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="432" as="sourcePoint"/><mxPoint x="300" y="432" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s6" value="verifyJoin(C1) + TOFU pin (NEW / MATCH / CHANGED)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="462" width="380" height="46" as="geometry"/></mxCell>
        <mxCell id="s7" value="&lt;b&gt;TCP CONNECT + ECDH&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C2 sends its ephemeral Curve25519 pubkey&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="548" as="sourcePoint"/><mxPoint x="300" y="548" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s8" value="&lt;b&gt;ECDH pubkey + encrypted INTRO&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;host ephemeral Curve25519 pubkey (raw); then host INTRO: nick ‖ avatar ‖ session_id ‖ host Ed25519 pubkey ‖ self-sig&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="604" as="sourcePoint"/><mxPoint x="1260" y="604" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s9" value="deriveChannelSecret(C2) → C2 AES-256 + HMAC-256 keys. C2 captures session_id + pins the host identity from the encrypted INTRO (verifyJoin + TOFU)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="634" width="380" height="61" as="geometry"/></mxCell>
        <mxCell id="s10" value="&lt;b&gt;JOIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C2 pubkey + Ed25519 self-sig «JOIN\0» ‖ session_id ‖ nick ‖ pubkey&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="735" as="sourcePoint"/><mxPoint x="300" y="735" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s11" value="verifyJoin(C2) + TOFU pin." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="765" width="380" height="31" as="geometry"/></mxCell>
        <mxCell id="s12" value="GENESIS: HOST, C1 and C2 each derive the 52 Ristretto255 points locally — it NEVER travels. Public anchor decks[0]." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="810" width="640" height="46" as="geometry"/></mxCell>
        <mxCell id="s13" value="&lt;b&gt;HAND_READY&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C1: new-hand barrier&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="896" as="sourcePoint"/><mxPoint x="300" y="896" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s14" value="&lt;b&gt;HAND_READY&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C2: new-hand barrier&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="952" as="sourcePoint"/><mxPoint x="300" y="952" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s15" value="&lt;b&gt;START_SRA_CASCADE&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;releases the cascade · HOST mints HAND_ID (random 16 B, delivered in MEGAPACKET)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="1006" as="sourcePoint"/><mxPoint x="780" y="1006" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s16" value="&lt;b&gt;START_SRA_CASCADE&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;releases the cascade · HOST mints HAND_ID (random 16 B, delivered in MEGAPACKET)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="1060" as="sourcePoint"/><mxPoint x="1260" y="1060" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s17" value="HOST applies its own k_pocket over the genesis + Fisher-Yates AES-256-CTR shuffle.
Every member holds two ephemeral scalars: k_pocket and k_community." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="1150" width="380" height="76" as="geometry"/></mxCell>
        <mxCell id="s18" value="&lt;b&gt;DECK_CASCADE_REQ&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;deck after HOST&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="1266" as="sourcePoint"/><mxPoint x="780" y="1266" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s19" value="validates 52 points · generates k_pocket / k_community · lock + shuffle
· commitments K_pocket=k·B, K_community=k·B" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="796" y="1296" width="380" height="61" as="geometry"/></mxCell>
        <mxCell id="s20" value="&lt;b&gt;DECK_CASCADE_RESP&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;nick ‖ deck′ ‖ K_pocket(C1) ‖ K_community(C1)   — fast, NO proof&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="1397" as="sourcePoint"/><mxPoint x="300" y="1397" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s21" value="&lt;b&gt;DECK_CASCADE_PROOF&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;hash(deck′) ‖ Bayer-Groth step proof — ASYNC, sent after the RESP · does NOT block the deal&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="1453" as="sourcePoint"/><mxPoint x="300" y="1453" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s22" value="&lt;b&gt;DECK_CASCADE_REQ&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;deck after C1&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="1509" as="sourcePoint"/><mxPoint x="1260" y="1509" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s23" value="validates · generates k_pocket / k_community · lock + shuffle
· K commitments" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="1276" y="1539" width="380" height="61" as="geometry"/></mxCell>
        <mxCell id="s24" value="&lt;b&gt;DECK_CASCADE_RESP&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;nick ‖ deck″ ‖ K_pocket(C2) ‖ K_community(C2)   — fast, NO proof&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="1640" as="sourcePoint"/><mxPoint x="300" y="1640" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s25" value="&lt;b&gt;DECK_CASCADE_PROOF&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;hash(deck″) ‖ Bayer-Groth step proof — ASYNC · does NOT block the deal&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="1696" as="sourcePoint"/><mxPoint x="300" y="1696" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s26" value="opt. B1 — the step proof is DECOUPLED from the RESP: each peer answers the cascade FAST (deck + commitments) and sends its Bayer-Groth proof separately (DECK_CASCADE_PROOF). The host collects them OFF the deal path (collectAsyncCascadeProofs — matched by hash(deckOut), 45 s window), so the ~0.1–9 s prove never stalls dealing. They feed the DUALLOCK_BUNDLE, assembled + broadcast during betting." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="1726" width="640" height="91" as="geometry"/></mxCell>
        <mxCell id="s27" value="HOST rotates its own community slots locally: strip k_pocket, re-lock under k_community + RotationProof." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="1831" width="380" height="61" as="geometry"/></mxCell>
        <mxCell id="s28" value="&lt;b&gt;DECK_ROTATION_REQ&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;community slots only&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="1932" as="sourcePoint"/><mxPoint x="780" y="1932" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s29" value="strip k_pocket + re-lock under k_community (combined scalar s = u·k_comm)
+ RotationProof (batch-DLEQ of an in-place re-key, no reordering)" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="796" y="1962" width="380" height="76" as="geometry"/></mxCell>
        <mxCell id="s30" value="&lt;b&gt;DECK_ROTATION_RESP&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;rotated deck ‖ RotationProof(C1)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="2078" as="sourcePoint"/><mxPoint x="300" y="2078" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s31" value="&lt;b&gt;DECK_ROTATION_REQ&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;community slots only&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2134" as="sourcePoint"/><mxPoint x="1260" y="2134" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s32" value="strip k_pocket + re-lock under k_community + RotationProof" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="1276" y="2164" width="380" height="46" as="geometry"/></mxCell>
        <mxCell id="s33" value="&lt;b&gt;DECK_ROTATION_RESP&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;rotated deck ‖ RotationProof(C2)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="2250" as="sourcePoint"/><mxPoint x="300" y="2250" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s34" value="&lt;b&gt;MEGAPACKET&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;final deck (pocket intact + rotated community) ‖ HAND_ID ‖ ring order ‖ K commitments&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2304" as="sourcePoint"/><mxPoint x="780" y="2304" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s35" value="&lt;b&gt;MEGAPACKET&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;final deck (pocket intact + rotated community) ‖ HAND_ID ‖ ring order ‖ K commitments&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2358" as="sourcePoint"/><mxPoint x="1260" y="2358" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s36" value="H_0 = SHA-256( «HAND\0» ‖ HAND_ID ‖ N ‖ Σ sorted[id‖K_pocket‖K_community] ‖ SHA-256(deck) )  — seeds the state chain" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="2388" width="640" height="46" as="geometry"/></mxCell>
        <mxCell id="s37" value="HOST extends one DealChain per slot (anchor = MEGAPACKET point) and strips its own lock locally, each with a per-card DLEQ proof." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="2508" width="380" height="61" as="geometry"/></mxCell>
        <mxCell id="s38" value="&lt;b&gt;REQ_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;phase = POCKET · strip C1 k_pocket from the OTHER slots&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2609" as="sourcePoint"/><mxPoint x="780" y="2609" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s39" value="verifies each chain anchors to its MEGAPACKET · applies k_pocket⁻¹
+ attaches a DLEQ proof (Chaum-Pedersen, dom. «SRA_DLEQ\0»).
Guard: REFUSES its own slot (anti self-strip) → otherwise LOCKDOWN." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="796" y="2639" width="380" height="106" as="geometry"/></mxCell>
        <mxCell id="s40" value="&lt;b&gt;RESP_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;extended chain + DLEQ&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="2785" as="sourcePoint"/><mxPoint x="300" y="2785" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s41" value="&lt;b&gt;REQ_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;phase = POCKET · strip C2 k_pocket from the OTHER slots&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2841" as="sourcePoint"/><mxPoint x="1260" y="2841" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s42" value="anchor check · applies k_pocket⁻¹ + DLEQ · refuses its own slot" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="1276" y="2871" width="380" height="46" as="geometry"/></mxCell>
        <mxCell id="s43" value="&lt;b&gt;RESP_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;extended chain + DLEQ&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="2957" as="sourcePoint"/><mxPoint x="300" y="2957" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s44" value="verifies chains vs each K_pocket · takes the tail = «single-locked» residual per player." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="2987" width="380" height="46" as="geometry"/></mxCell>
        <mxCell id="s45" value="&lt;b&gt;POCKET_CARDS&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;single-locked residual per player · each recipient removes its own k_pocket and resolves against genesis&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3071" as="sourcePoint"/><mxPoint x="780" y="3071" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s46" value="&lt;b&gt;POCKET_CARDS&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;single-locked residual per player · each recipient removes its own k_pocket and resolves against genesis&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3125" as="sourcePoint"/><mxPoint x="1260" y="3125" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s47" value="guardarFosilSRA: persists the state for crash recovery." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="3155" width="380" height="46" as="geometry"/></mxCell>
        <mxCell id="s48" value="&lt;b&gt;DUALLOCK_BUNDLE&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;full genesis→MEGAPACKET proof (Bayer-Groth + batch-DLEQ) — assembled from the async step proofs, broadcast DURING betting, off the deal path&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3299" as="sourcePoint"/><mxPoint x="780" y="3299" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s49" value="&lt;b&gt;DUALLOCK_BUNDLE&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;full genesis→MEGAPACKET proof (Bayer-Groth + batch-DLEQ) — assembled from the async step proofs, broadcast DURING betting, off the deal path&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3353" as="sourcePoint"/><mxPoint x="1260" y="3353" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s50" value="Once the host has collected the async DECK_CASCADE_PROOF from every peer it assembles the honest-shuffle bundle and broadcasts it here. C1 and C2 enqueue it in ShuffleVerificationQueue and verify it in the BACKGROUND against their own recomputed genesis + pocket/community boundary — zero impact on play. A missing/failed proof only sets receipt flags (bit1 deck-pending / bit1+bit2 no-proof), never blocks the hand." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="3383" width="640" height="91" as="geometry"/></mxCell>
        <mxCell id="s51" value="&lt;b&gt;ACTION&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;( FOLD · CHECK · CALL · BET · RAISE · ALL-IN ) · C1 acts, signs «ACTION\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="3514" as="sourcePoint"/><mxPoint x="300" y="3514" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s52" value="&lt;b&gt;ACTION (relay)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;host forwards C1 signed action to C2&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3570" as="sourcePoint"/><mxPoint x="1260" y="3570" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s53" value="&lt;b&gt;ACTION&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;( FOLD · CHECK · CALL · BET · RAISE · ALL-IN ) · C2 acts, signs «ACTION\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="3626" as="sourcePoint"/><mxPoint x="300" y="3626" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s54" value="&lt;b&gt;ACTION (relay)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;host forwards C2 signed action to C1&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3682" as="sourcePoint"/><mxPoint x="780" y="3682" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s55" value="&lt;b&gt;ACTION&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;( FOLD · CHECK · CALL · BET · RAISE · ALL-IN ) · HOST acts, signs «ACTION\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3736" as="sourcePoint"/><mxPoint x="780" y="3736" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s56" value="&lt;b&gt;ACTION&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;( FOLD · CHECK · CALL · BET · RAISE · ALL-IN ) · HOST acts, signs «ACTION\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3790" as="sourcePoint"/><mxPoint x="1260" y="3790" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s57" value="Each ACTION is a 92 B canonical record (cents, NFC); the actor signs it «ACTION\0», every peer verifies the sig and binds type/amount/player/hand to the played action (bad sig or mismatch ⇒ synthetic FOLD + flag), then absorbs H_{t+1} = SHA-256( record ‖ sig ). Acting order follows the button &amp;amp; blinds." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="3820" width="640" height="76" as="geometry"/></mxCell>
        <mxCell id="s58" value="HOST strips its own k_community on the flop slots locally (DLEQ)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="3970" width="380" height="46" as="geometry"/></mxCell>
        <mxCell id="s59" value="&lt;b&gt;REQ_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;phase = COMMUNITY (flop offset)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="4056" as="sourcePoint"/><mxPoint x="780" y="4056" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s60" value="strips its k_community over the copies of the others · DLEQ
+ GATE-6: refuses if the strip would reveal a genesis card too early." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="796" y="4086" width="380" height="76" as="geometry"/></mxCell>
        <mxCell id="s61" value="&lt;b&gt;RESP_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;chain + DLEQ&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="4202" as="sourcePoint"/><mxPoint x="300" y="4202" as="targetPoint"/></mxGeometry></mxCell>
