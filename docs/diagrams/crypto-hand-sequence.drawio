        <mxCell id="s136" value="PHASE 4b · Turn — community reveal" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=1.5;opacity=55;fontColor=#222222;fontStyle=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="20" y="4550" width="1660" height="588" as="geometry"/></mxCell>
