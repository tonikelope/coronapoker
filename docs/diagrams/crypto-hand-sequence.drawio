        <mxCell id="s145" style="endArrow=none;html=1;strokeColor=#5B82BE;strokeWidth=2;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="114" as="sourcePoint"/><mxPoint x="1260" y="7986" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s146" value="&lt;b&gt;HOST&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;Dealer + Player · server&lt;/span&gt;" style="rounded=1;arcSize=20;whiteSpace=wrap;html=1;fillColor=#E8ECF1;strokeColor=#2E3A48;strokeWidth=2;fontColor=#1f1f1f;fontSize=12;" vertex="1" parent="1"><mxGeometry x="205" y="56" width="190" height="58" as="geometry"/></mxCell>
        <mxCell id="s147" value="&lt;b&gt;HOST&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;Dealer + Player · server&lt;/span&gt;" style="rounded=1;arcSize=20;whiteSpace=wrap;html=1;fillColor=#E8ECF1;strokeColor=#2E3A48;strokeWidth=2;fontColor=#1f1f1f;fontSize=12;" vertex="1" parent="1"><mxGeometry x="205" y="7986" width="190" height="58" as="geometry"/></mxCell>
        <mxCell id="s148" value="&lt;b&gt;CLIENT 1&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;human&lt;/span&gt;" style="rounded=1;arcSize=20;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=2;fontColor=#1f1f1f;fontSize=12;" vertex="1" parent="1"><mxGeometry x="685" y="56" width="190" height="58" as="geometry"/></mxCell>
        <mxCell id="s149" value="&lt;b&gt;CLIENT 1&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;human&lt;/span&gt;" style="rounded=1;arcSize=20;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=2;fontColor=#1f1f1f;fontSize=12;" vertex="1" parent="1"><mxGeometry x="685" y="7986" width="190" height="58" as="geometry"/></mxCell>
        <mxCell id="s150" value="&lt;b&gt;CLIENT 2&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;human&lt;/span&gt;" style="rounded=1;arcSize=20;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=2;fontColor=#1f1f1f;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1165" y="56" width="190" height="58" as="geometry"/></mxCell>
        <mxCell id="s151" value="&lt;b&gt;CLIENT 2&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;human&lt;/span&gt;" style="rounded=1;arcSize=20;whiteSpace=wrap;html=1;fillColor=#E6EFFB;strokeColor=#5B82BE;strokeWidth=2;fontColor=#1f1f1f;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1165" y="7986" width="190" height="58" as="geometry"/></mxCell>
        <mxCell id="t1" value="CoronaPoker — Per-hand cryptographic protocol (verifiable SRA)" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#1a1a2e;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="20" y="6" width="1400" height="28" as="geometry"/></mxCell>
        <mxCell id="t2" value="One COMPLETE hand — all four streets (preflop · flop · turn · river) through to showdown — with every step shown explicitly. 3-player game: HOST (dealer + player, server) + 2 human clients. Time flows downward. ── solid = send · ┄ dashed = response / async · purple = host push (one explicit arrow per client)." style="text;html=1;fontSize=12;fontStyle=2;fontColor=#5a5a6a;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="20" y="32" width="1640" height="20" as="geometry"/></mxCell>
        <mxCell id="s2" value="&lt;b&gt;TCP CONNECT + ECDH&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C1 sends its ephemeral Curve25519 pubkey&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="200" as="sourcePoint"/><mxPoint x="300" y="200" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s3" value="&lt;b&gt;ECDH pubkey + encrypted INTRO&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;host ephemeral Curve25519 pubkey (raw); then, on the now-encrypted channel, the host INTRO: nick ‖ avatar ‖ session_id ‖ host Ed25519 pubkey ‖ self-sig «JOIN\0»(session_id‖nick‖pubkey)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="256" as="sourcePoint"/><mxPoint x="780" y="256" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s4" value="Both sides run ECDH → deriveChannelSecret: HMAC-SHA512(shared ‖ password) → AES-256 channel key + HMAC-256 key. C1 then captures session_id and pins the host identity FROM THE ENCRYPTED INTRO — verifyJoin(host self-sig) + TOFU (NEW / MATCH / CHANGED). The raw ECDH bytes carry no identity." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="286" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s5" value="&lt;b&gt;JOIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C1 pubkey + Ed25519 self-sig «JOIN\0» ‖ session_id ‖ nick ‖ pubkey&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="363" as="sourcePoint"/><mxPoint x="300" y="363" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s6" value="verifyJoin(C1) + TOFU pin (NEW / MATCH / CHANGED)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="393" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s7" value="&lt;b&gt;TCP CONNECT + ECDH&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C2 sends its ephemeral Curve25519 pubkey&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="470" as="sourcePoint"/><mxPoint x="300" y="470" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s8" value="&lt;b&gt;ECDH pubkey + encrypted INTRO&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;host ephemeral Curve25519 pubkey (raw); then host INTRO: nick ‖ avatar ‖ session_id ‖ host Ed25519 pubkey ‖ self-sig&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="526" as="sourcePoint"/><mxPoint x="1260" y="526" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s9" value="deriveChannelSecret(C2) → C2 AES-256 + HMAC-256 keys. C2 captures session_id + pins the host identity from the encrypted INTRO (verifyJoin + TOFU)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="556" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s10" value="&lt;b&gt;JOIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C2 pubkey + Ed25519 self-sig «JOIN\0» ‖ session_id ‖ nick ‖ pubkey&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="633" as="sourcePoint"/><mxPoint x="300" y="633" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s11" value="verifyJoin(C2) + TOFU pin." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="663" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s12" value="GENESIS: HOST, C1 and C2 each derive the 52 Ristretto255 points locally — it NEVER travels. Public anchor decks[0]." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="714" width="640" height="37" as="geometry"/></mxCell>
        <mxCell id="s13" value="&lt;b&gt;HAND_READY&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C1: new-hand barrier&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="791" as="sourcePoint"/><mxPoint x="300" y="791" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s14" value="&lt;b&gt;HAND_READY&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C2: new-hand barrier&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="847" as="sourcePoint"/><mxPoint x="300" y="847" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s15" value="&lt;b&gt;START_SRA_CASCADE&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;releases the cascade · HOST mints HAND_ID (random 16 B, delivered in MEGAPACKET)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="901" as="sourcePoint"/><mxPoint x="780" y="901" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s16" value="&lt;b&gt;START_SRA_CASCADE&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;releases the cascade · HOST mints HAND_ID (random 16 B, delivered in MEGAPACKET)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="955" as="sourcePoint"/><mxPoint x="1260" y="955" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s17" value="HOST applies its own k_pocket over the genesis + Fisher-Yates AES-256-CTR shuffle.
Every member holds two ephemeral scalars: k_pocket and k_community." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="1045" width="380" height="52" as="geometry"/></mxCell>
        <mxCell id="s18" value="&lt;b&gt;DECK_CASCADE_REQ&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;deck after HOST&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="1137" as="sourcePoint"/><mxPoint x="780" y="1137" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s19" value="validates 52 points · generates k_pocket / k_community · lock + shuffle
· commitments K_pocket=k·B, K_community=k·B" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="796" y="1167" width="380" height="52" as="geometry"/></mxCell>
        <mxCell id="s20" value="&lt;b&gt;DECK_CASCADE_RESP&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;nick ‖ deck′ ‖ K_pocket(C1) ‖ K_community(C1)   — fast, NO proof&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="1259" as="sourcePoint"/><mxPoint x="300" y="1259" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s21" value="&lt;b&gt;DECK_CASCADE_PROOF&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;hash(deck′) ‖ Bayer-Groth step proof — ASYNC, sent after the RESP · does NOT block the deal&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="1315" as="sourcePoint"/><mxPoint x="300" y="1315" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s22" value="&lt;b&gt;DECK_CASCADE_REQ&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;deck after C1&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="1371" as="sourcePoint"/><mxPoint x="1260" y="1371" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s23" value="validates · generates k_pocket / k_community · lock + shuffle
· K commitments" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="1276" y="1401" width="380" height="52" as="geometry"/></mxCell>
        <mxCell id="s24" value="&lt;b&gt;DECK_CASCADE_RESP&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;nick ‖ deck″ ‖ K_pocket(C2) ‖ K_community(C2)   — fast, NO proof&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="1493" as="sourcePoint"/><mxPoint x="300" y="1493" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s25" value="&lt;b&gt;DECK_CASCADE_PROOF&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;hash(deck″) ‖ Bayer-Groth step proof — ASYNC · does NOT block the deal&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="1549" as="sourcePoint"/><mxPoint x="300" y="1549" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s26" value="opt. B1 — the step proof is DECOUPLED from the RESP: each peer answers the cascade FAST (deck + commitments) and sends its Bayer-Groth proof separately (DECK_CASCADE_PROOF). The host collects them OFF the deal path (collectAsyncCascadeProofs — matched by hash(deckOut), 45 s window), so the ~0.1–9 s prove never stalls dealing. They feed the DUALLOCK_BUNDLE, assembled + broadcast during betting." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="1579" width="640" height="37" as="geometry"/></mxCell>
        <mxCell id="s27" value="HOST rotates its own community slots locally: strip k_pocket, re-lock under k_community + RotationProof." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="1630" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s28" value="&lt;b&gt;DECK_ROTATION_REQ&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;community slots only&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="1707" as="sourcePoint"/><mxPoint x="780" y="1707" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s29" value="strip k_pocket + re-lock under k_community (combined scalar s = u·k_comm)
+ RotationProof (batch-DLEQ of an in-place re-key, no reordering)" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="796" y="1737" width="380" height="52" as="geometry"/></mxCell>
        <mxCell id="s30" value="&lt;b&gt;DECK_ROTATION_RESP&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;rotated deck ‖ RotationProof(C1)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="1829" as="sourcePoint"/><mxPoint x="300" y="1829" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s31" value="&lt;b&gt;DECK_ROTATION_REQ&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;community slots only&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="1885" as="sourcePoint"/><mxPoint x="1260" y="1885" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s32" value="strip k_pocket + re-lock under k_community + RotationProof" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="1276" y="1915" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s33" value="&lt;b&gt;DECK_ROTATION_RESP&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;rotated deck ‖ RotationProof(C2)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="1992" as="sourcePoint"/><mxPoint x="300" y="1992" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s34" value="&lt;b&gt;MEGAPACKET&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;final deck (pocket intact + rotated community) ‖ HAND_ID ‖ ring order ‖ K commitments&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2046" as="sourcePoint"/><mxPoint x="780" y="2046" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s35" value="&lt;b&gt;MEGAPACKET&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;final deck (pocket intact + rotated community) ‖ HAND_ID ‖ ring order ‖ K commitments&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2100" as="sourcePoint"/><mxPoint x="1260" y="2100" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s36" value="H_0 = SHA-256( «HAND\0» ‖ HAND_ID ‖ N ‖ Σ sorted[id‖K_pocket‖K_community] ‖ SHA-256(deck) )  — seeds the state chain" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="2130" width="640" height="37" as="geometry"/></mxCell>
        <mxCell id="s37" value="HOST extends one DealChain per slot (anchor = MEGAPACKET point) and strips its own lock locally, each with a per-card DLEQ proof." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="2241" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s38" value="&lt;b&gt;REQ_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;phase = POCKET · strip C1 k_pocket from the OTHER slots&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2318" as="sourcePoint"/><mxPoint x="780" y="2318" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s39" value="verifies each chain anchors to its MEGAPACKET · applies k_pocket⁻¹
+ attaches a DLEQ proof (Chaum-Pedersen, dom. «SRA_DLEQ\0»).
Guard: REFUSES its own slot (anti self-strip) → otherwise LOCKDOWN." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="796" y="2348" width="380" height="67" as="geometry"/></mxCell>
        <mxCell id="s40" value="&lt;b&gt;RESP_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;extended chain + DLEQ&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="2455" as="sourcePoint"/><mxPoint x="300" y="2455" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s41" value="&lt;b&gt;REQ_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;phase = POCKET · strip C2 k_pocket from the OTHER slots&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2511" as="sourcePoint"/><mxPoint x="1260" y="2511" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s42" value="anchor check · applies k_pocket⁻¹ + DLEQ · refuses its own slot" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="1276" y="2541" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s43" value="&lt;b&gt;RESP_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;extended chain + DLEQ&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="2618" as="sourcePoint"/><mxPoint x="300" y="2618" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s44" value="verifies chains vs each K_pocket · takes the tail = «single-locked» residual per player." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="2648" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s45" value="&lt;b&gt;POCKET_CARDS&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;single-locked residual per player · each recipient removes its own k_pocket and resolves against genesis&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2723" as="sourcePoint"/><mxPoint x="780" y="2723" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s46" value="&lt;b&gt;POCKET_CARDS&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;single-locked residual per player · each recipient removes its own k_pocket and resolves against genesis&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2777" as="sourcePoint"/><mxPoint x="1260" y="2777" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s47" value="guardarFosilSRA: persists the state for crash recovery." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="2807" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s48" value="&lt;b&gt;DUALLOCK_BUNDLE&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;full genesis→MEGAPACKET proof (Bayer-Groth + batch-DLEQ) — assembled from the async step proofs, broadcast DURING betting, off the deal path&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2942" as="sourcePoint"/><mxPoint x="780" y="2942" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s49" value="&lt;b&gt;DUALLOCK_BUNDLE&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;full genesis→MEGAPACKET proof (Bayer-Groth + batch-DLEQ) — assembled from the async step proofs, broadcast DURING betting, off the deal path&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2996" as="sourcePoint"/><mxPoint x="1260" y="2996" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s50" value="Once the host has collected the async DECK_CASCADE_PROOF from every peer it assembles the honest-shuffle bundle and broadcasts it here. C1 and C2 enqueue it in ShuffleVerificationQueue and verify it in the BACKGROUND against their own recomputed genesis + pocket/community boundary — zero impact on play. A missing/failed proof only sets receipt flags (bit1 deck-pending / bit1+bit2 no-proof), never blocks the hand." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="3026" width="640" height="37" as="geometry"/></mxCell>
        <mxCell id="s51" value="&lt;b&gt;ACTION&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;( FOLD · CHECK · CALL · BET · RAISE · ALL-IN ) · C1 acts, signs «ACTION\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="3103" as="sourcePoint"/><mxPoint x="300" y="3103" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s52" value="&lt;b&gt;ACTION (relay)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;host forwards C1 signed action to C2&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3159" as="sourcePoint"/><mxPoint x="1260" y="3159" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s53" value="&lt;b&gt;ACTION&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;( FOLD · CHECK · CALL · BET · RAISE · ALL-IN ) · C2 acts, signs «ACTION\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="3215" as="sourcePoint"/><mxPoint x="300" y="3215" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s54" value="&lt;b&gt;ACTION (relay)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;host forwards C2 signed action to C1&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3271" as="sourcePoint"/><mxPoint x="780" y="3271" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s55" value="&lt;b&gt;ACTION&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;( FOLD · CHECK · CALL · BET · RAISE · ALL-IN ) · HOST acts, signs «ACTION\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3325" as="sourcePoint"/><mxPoint x="780" y="3325" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s56" value="&lt;b&gt;ACTION&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;( FOLD · CHECK · CALL · BET · RAISE · ALL-IN ) · HOST acts, signs «ACTION\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3379" as="sourcePoint"/><mxPoint x="1260" y="3379" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s57" value="Each ACTION is a 92 B canonical record (cents, NFC); the actor signs it «ACTION\0», every peer verifies the sig and binds type/amount/player/hand to the played action (bad sig or mismatch ⇒ synthetic FOLD + flag), then absorbs H_{t+1} = SHA-256( record ‖ sig ). Acting order follows the button &amp;amp; blinds." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="3409" width="640" height="37" as="geometry"/></mxCell>
        <mxCell id="s58" value="HOST strips its own k_community on the flop slots locally (DLEQ)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="3520" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s59" value="&lt;b&gt;REQ_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;phase = COMMUNITY (flop offset)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3597" as="sourcePoint"/><mxPoint x="780" y="3597" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s60" value="strips its k_community over the copies of the others · DLEQ
+ GATE-6: refuses if the strip would reveal a genesis card too early." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="796" y="3627" width="380" height="52" as="geometry"/></mxCell>
        <mxCell id="s61" value="&lt;b&gt;RESP_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;chain + DLEQ&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="3719" as="sourcePoint"/><mxPoint x="300" y="3719" as="targetPoint"/></mxGeometry></mxCell>
