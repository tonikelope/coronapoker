        <mxCell id="s24" value="HOST rotates its own community slots locally: strip k_pocket, re-lock under k_community + RotationProof." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="1482" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s25" value="&lt;b&gt;DECK_ROTATION_REQ&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;community slots only&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="1559" as="sourcePoint"/><mxPoint x="780" y="1559" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s26" value="strip k_pocket + re-lock under k_community (combined scalar s = u·k_comm)
+ RotationProof (batch-DLEQ of an in-place re-key, no reordering)" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="796" y="1589" width="380" height="52" as="geometry"/></mxCell>
        <mxCell id="s27" value="&lt;b&gt;DECK_ROTATION_RESP&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;rotated deck ‖ RotationProof(C1)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="1681" as="sourcePoint"/><mxPoint x="300" y="1681" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s28" value="&lt;b&gt;DECK_ROTATION_REQ&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;community slots only&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="1737" as="sourcePoint"/><mxPoint x="1260" y="1737" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s29" value="strip k_pocket + re-lock under k_community + RotationProof" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="1276" y="1767" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s30" value="&lt;b&gt;DECK_ROTATION_RESP&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;rotated deck ‖ RotationProof(C2)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="1844" as="sourcePoint"/><mxPoint x="300" y="1844" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s31" value="&lt;b&gt;MEGAPACKET&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;final deck (pocket intact + rotated community) ‖ HAND_ID ‖ ring order ‖ K commitments&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="1898" as="sourcePoint"/><mxPoint x="780" y="1898" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s32" value="&lt;b&gt;MEGAPACKET&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;final deck (pocket intact + rotated community) ‖ HAND_ID ‖ ring order ‖ K commitments&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="1952" as="sourcePoint"/><mxPoint x="1260" y="1952" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s33" value="H_0 = SHA-256( «HAND\0» ‖ HAND_ID ‖ N ‖ Σ sorted[id‖K_pocket‖K_community] ‖ SHA-256(deck) )  — seeds the state chain" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="1982" width="640" height="37" as="geometry"/></mxCell>
        <mxCell id="s34" value="&lt;b&gt;DUALLOCK_BUNDLE&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;full genesis→MEGAPACKET proof (Bayer-Groth + batch-DLEQ), async&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2057" as="sourcePoint"/><mxPoint x="780" y="2057" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s35" value="&lt;b&gt;DUALLOCK_BUNDLE&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;full genesis→MEGAPACKET proof (Bayer-Groth + batch-DLEQ), async&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2111" as="sourcePoint"/><mxPoint x="1260" y="2111" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s36" value="C1 and C2 each enqueue it in ShuffleVerificationQueue and verify it against their own recomputed genesis + pocket/community boundary." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="2141" width="640" height="37" as="geometry"/></mxCell>
        <mxCell id="s37" value="HOST extends one DealChain per slot (anchor = MEGAPACKET point) and strips its own lock locally, each with a per-card DLEQ proof." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="2252" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s38" value="&lt;b&gt;REQ_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;phase = POCKET · strip C1 k_pocket from the OTHER slots&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2329" as="sourcePoint"/><mxPoint x="780" y="2329" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s39" value="verifies each chain anchors to its MEGAPACKET · applies k_pocket⁻¹
+ attaches a DLEQ proof (Chaum-Pedersen, dom. «SRA_DLEQ\0»).
Guard: REFUSES its own slot (anti self-strip) → otherwise LOCKDOWN." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="796" y="2359" width="380" height="67" as="geometry"/></mxCell>
        <mxCell id="s40" value="&lt;b&gt;RESP_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;extended chain + DLEQ&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="2466" as="sourcePoint"/><mxPoint x="300" y="2466" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s41" value="&lt;b&gt;REQ_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;phase = POCKET · strip C2 k_pocket from the OTHER slots&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2522" as="sourcePoint"/><mxPoint x="1260" y="2522" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s42" value="anchor check · applies k_pocket⁻¹ + DLEQ · refuses its own slot" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="1276" y="2552" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s43" value="&lt;b&gt;RESP_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;extended chain + DLEQ&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="2629" as="sourcePoint"/><mxPoint x="300" y="2629" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s44" value="verifies chains vs each K_pocket · takes the tail = «single-locked» residual per player." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="2659" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s45" value="&lt;b&gt;POCKET_CARDS&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;single-locked residual per player · each recipient removes its own k_pocket and resolves against genesis&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2734" as="sourcePoint"/><mxPoint x="780" y="2734" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s46" value="&lt;b&gt;POCKET_CARDS&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;single-locked residual per player · each recipient removes its own k_pocket and resolves against genesis&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="2788" as="sourcePoint"/><mxPoint x="1260" y="2788" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s47" value="guardarFosilSRA: persists the state for crash recovery." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="2818" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s48" value="&lt;b&gt;ACTION&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;( FOLD · CHECK · CALL · BET · RAISE · ALL-IN ) · C1 acts, signs «ACTION\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="2955" as="sourcePoint"/><mxPoint x="300" y="2955" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s49" value="&lt;b&gt;ACTION (relay)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;host forwards C1 signed action to C2&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3011" as="sourcePoint"/><mxPoint x="1260" y="3011" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s50" value="&lt;b&gt;ACTION&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;( FOLD · CHECK · CALL · BET · RAISE · ALL-IN ) · C2 acts, signs «ACTION\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="3067" as="sourcePoint"/><mxPoint x="300" y="3067" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s51" value="&lt;b&gt;ACTION (relay)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;host forwards C2 signed action to C1&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3123" as="sourcePoint"/><mxPoint x="780" y="3123" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s52" value="&lt;b&gt;ACTION&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;( FOLD · CHECK · CALL · BET · RAISE · ALL-IN ) · HOST acts, signs «ACTION\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3177" as="sourcePoint"/><mxPoint x="780" y="3177" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s53" value="&lt;b&gt;ACTION&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C2&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;( FOLD · CHECK · CALL · BET · RAISE · ALL-IN ) · HOST acts, signs «ACTION\0»&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3231" as="sourcePoint"/><mxPoint x="1260" y="3231" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s54" value="Each ACTION is a 92 B canonical record (cents, NFC); the actor signs it «ACTION\0», every peer verifies the sig (invalid ⇒ synthetic FOLD + flag) and absorbs H_{t+1} = SHA-256( record ‖ sig ). Acting order follows the button &amp;amp; blinds." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="3261" width="640" height="37" as="geometry"/></mxCell>
        <mxCell id="s55" value="HOST strips its own k_community on the flop slots locally (DLEQ)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="3372" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s56" value="&lt;b&gt;REQ_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;phase = COMMUNITY (flop offset)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3449" as="sourcePoint"/><mxPoint x="780" y="3449" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s57" value="strips its k_community over the copies of the others · DLEQ
+ GATE-6: refuses if the strip would reveal a genesis card too early." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="796" y="3479" width="380" height="52" as="geometry"/></mxCell>
        <mxCell id="s58" value="&lt;b&gt;RESP_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;chain + DLEQ&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="3571" as="sourcePoint"/><mxPoint x="300" y="3571" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s59" value="&lt;b&gt;REQ_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;phase = COMMUNITY (flop offset)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3627" as="sourcePoint"/><mxPoint x="1260" y="3627" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s60" value="&lt;b&gt;RESP_SRA_UNLOCK_CHAIN&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;chain + DLEQ + GATE-6&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;dashPattern=8 5;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="3683" as="sourcePoint"/><mxPoint x="300" y="3683" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s61" value="&lt;b&gt;FLOP_PIECE&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C1 piece (only its k_community remains)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3739" as="sourcePoint"/><mxPoint x="780" y="3739" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s62" value="&lt;b&gt;FLOP_PIECE&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C2 piece (only its k_community remains)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3795" as="sourcePoint"/><mxPoint x="1260" y="3795" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="s63" value="&lt;b&gt;COMM_REVEAL&lt;/b&gt;  &lt;span style=&quot;font-size:9px;color:#7E57A6&quot;&gt;▶ to C1&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;signed ACTION_COMMUNITY record (3 cards packed in AMOUNT_CENTS)&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#7E57A6;strokeWidth=2.4;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="3849" as="sourcePoint"/><mxPoint x="780" y="3849" as="targetPoint"/></mxGeometry></mxCell>
