        <mxCell id="s11" value="verifyJoin(C2) + TOFU pin." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="316" y="678" width="380" height="37" as="geometry"/></mxCell>
        <mxCell id="s12" value="GENESIS: HOST, C1 and C2 each derive the 52 Ristretto255 points locally — it NEVER travels. Public anchor decks[0]." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF8D6;strokeColor=#D9C45A;strokeWidth=1.2;fontColor=#3a3320;fontSize=10;align=left;verticalAlign=middle;spacingLeft=8;spacingRight=6;size=12;" vertex="1" parent="1"><mxGeometry x="530" y="729" width="640" height="37" as="geometry"/></mxCell>
        <mxCell id="s13" value="&lt;b&gt;HAND_READY&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#333&quot;&gt;C1: new-hand barrier&lt;/span&gt;" style="endArrow=block;endFill=1;html=1;rounded=0;strokeColor=#34343a;strokeWidth=1.8;fontSize=10;verticalAlign=bottom;labelBackgroundColor=#FFFFFF;spacingBottom=4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="806" as="sourcePoint"/><mxPoint x="300" y="806" as="targetPoint"/></mxGeometry></mxCell>
